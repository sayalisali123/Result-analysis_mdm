# Example environment file for local development
# Copy this to .env and fill your own secrets.

GEMINI_API_KEY=your_gemini_api_key_here

# For Firebase, either set FIREBASE_CREDENTIALS as a JSON string
# or set FIREBASE_CREDENTIALS_PATH to the local path of your service account file.

# FIREBASE_CREDENTIALS={"type":"service_account", ... }
# FIREBASE_CREDENTIALS_PATH=student-portal-9f4f6-firebase-adminsdk-fbsvc-614a27b548.json